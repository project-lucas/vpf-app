# --- Supabase (Dashboard > Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Connexion directe Postgres (Dashboard > Settings > Database > Connection string, URI) ---
# Utilisée uniquement par `npm run migrate`
DATABASE_URL=postgresql://postgres.xxxx:MOT_DE_PASSE@aws-0-eu-west-3.pooler.supabase.com:5432/postgres

# --- Notifications push (générer avec `npm run vapid`) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@vpf.fr

# --- Cron (secret aléatoire de votre choix) ---
CRON_SECRET=change-me

# --- URL publique de l'app (pour les liens d'invitation) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
